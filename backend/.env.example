# 应用
APP_NAME=QA Admin Backend
DEBUG=false

# MySQL（本机 root/root 端口 13307）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13307
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=qa_admin

# JWT（生产务必修改）
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Redis（可选）
REDIS_URL=redis://127.0.0.1:6379/0

# CORS（生产建议写具体前端域名）
CORS_ORIGINS=["*"]
